    <content type="html"><![CDATA[<style>  /* 设置整个页面的字体 */  html, body, .markdown-body {    font-family: STXihei, "华文细黑", "Microsoft YaHei", "微软雅黑";    font-size: 15px;  }</style><h2 id="03-引擎"><a href="#03-引擎" class="headerlink" title="03 引擎"></a>03 引擎</h2><h2 id="04-文件系统"><a href="#04-文件系统" class="headerlink" title="04 文件系统"></a>04 文件系统</h2><h2 id="05-用法指导"><a href="#05-用法指导" class="headerlink" title="05 用法指导"></a>05 用法指导</h2><h3 id="5-1-建Catalog"><a href="#5-1-建Catalog" class="headerlink" title="5.1 建Catalog"></a>5.1 建Catalog</h3><h3 id="5-2-建表"><a href="#5-2-建表" class="headerlink" title="5.2 建表"></a>5.2 建表</h3><h3 id="5-3-改表"><a href="#5-3-改表" class="headerlink" title="5.3 改表"></a>5.3 改表</h3><h3 id="5-4-写表"><a href="#5-4-写表" class="headerlink" title="5.4 写表"></a>5.4 写表</h3><h3 id="5-5-查表"><a href="#5-5-查表" class="headerlink" title="5.5 查表"></a>5.5 查表</h3><h3 id="5-6-系统表"><a href="#5-6-系统表" class="headerlink" title="5.6 系统表"></a>5.6 系统表</h3><h3 id="5-7-Lookup-Joins"><a href="#5-7-Lookup-Joins" class="headerlink" title="5.7 Lookup Joins"></a>5.7 Lookup Joins</h3><h3 id="5-8-CDC-摄取"><a href="#5-8-CDC-摄取" class="headerlink" title="5.8 CDC 摄取"></a>5.8 CDC 摄取</h3><h2 id="06-运维调优"><a href="#06-运维调优" class="headerlink" title="06 运维调优"></a>06 运维调优</h2><h3 id="6-1-写性能"><a href="#6-1-写性能" class="headerlink" title="6.1 写性能"></a>6.1 写性能</h3><h3 id="6-2-读性能"><a href="#6-2-读性能" class="headerlink" title="6.2 读性能"></a>6.2 读性能</h3><h3 id="6-3-多表写"><a href="#6-3-多表写" class="headerlink" title="6.3 多表写"></a>6.3 多表写</h3><h3 id="6-4-管理分区"><a href="#6-4-管理分区" class="headerlink" title="6.4 管理分区"></a>6.4 管理分区</h3><h3 id="6-5-管理文件"><a href="#6-5-管理文件" class="headerlink" title="6.5 管理文件"></a>6.5 管理文件</h3><h3 id="6-6-重分桶"><a href="#6-6-重分桶" class="headerlink" title="6.6 重分桶"></a>6.6 重分桶</h3><h3 id="6-7-管理标记"><a href="#6-7-管理标记" class="headerlink" title="6.7 管理标记"></a>6.7 管理标记</h3><h3 id="6-8-配置"><a href="#6-8-配置" class="headerlink" title="6.8 配置"></a>6.8 配置</h3><h2 id="07-三方调用-API"><a href="#07-三方调用-API" class="headerlink" title="07 三方调用 API"></a>07 三方调用 API</h2><h2 id="08-引用说明"><a href="#08-引用说明" class="headerlink" title="08 引用说明"></a>08 引用说明</h2><section class="footnotes"><div class="footnote-list"><ol><li><span id="fn:1" class="footnote-text"><span>xxx<a href="#fnref:1" rev="footnote" class="footnote-backref"> ↩</a></span></span></li></ol></div></section>]]></content>
    
    
